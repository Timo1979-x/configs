        "conditionType": "BypassCondition",
        "pattern": "127.0.0.1"
      },
      {
        "conditionType": "BypassCondition",
        "pattern": "::1"
      },
      {
        "conditionType": "BypassCondition",
        "pattern": "localhost"
      }
    ],
    "color": "#99ccee",
    "fallbackProxy": {
      "host": "sing-box-proxy",
      "port": 1080,
      "scheme": "http"
    },
    "name": "sing-box-proxy",
